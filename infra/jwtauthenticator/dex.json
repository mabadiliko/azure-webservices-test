{
  "issuer": {
    "url": "https://dex.wsv2test.j26.se",
    "audiences": ["headlamp", "kubectl"]
  },
  "claimValidationRules": [
    {
      "expression": "has(claims.sub)",
      "message": "token must have a sub claim"
    }
  ],
  "claimMappings": {
    "username": {
      "expression": "'aks:jwt:' + claims.preferred_username"
    },
    "groups": {
      "expression": "has(claims.groups) ? dyn(claims.groups).map(g, 'aks:jwt:' + string(g)) : []"
    }
  },
  "userValidationRules": [
    {
      "expression": "user.username.startsWith('aks:jwt:')",
      "message": "username must carry the aks:jwt: prefix"
    }
  ]
}
