# Per-developer namespace-scoped access. Copy this file to
# serviceaccount-rbac.yaml (dropping the .example) to activate it — the .example
# is never synced, so an unfilled placeholder can't leak in.
#
# NAMING: the ServiceAccount name is ALWAYS the developer's GitHub username,
# lowercased. GitHub usernames are alphanumerics and single hyphens only, so
# they are always valid ServiceAccount names — no other rule to remember. This
# also keeps the cluster identity tied to the same identity used for the repo.
# Record the email in the annotation (an '@' can't appear in the name).
#
# ACCESS: clusterRole `admin` gives full control WITHIN the namespace; use
# `view` for read-only.
#
# For more than one developer, add another ServiceAccount + RoleBinding pair
# (each SA name must be unique within the namespace).
#
# NAMESPACES: the ServiceAccount is the developer's identity and lives in ONE
# namespace. To grant access, add a RoleBinding IN each namespace the developer
# should manage, all pointing back at that one SA. The body below is the
# single-namespace case; for a dev/prod (or +staging) project see the
# commented multi-namespace block at the bottom of this file.
#
# After committing (ArgoCD creates the SA + RoleBinding), mint a login token:
#   kubectl -n PROJECT create token GITHUB_USERNAME --duration=8760h
# and give it to the developer to paste into Headlamp.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: GITHUB_USERNAME
  namespace: PROJECT
  annotations:
    scouterna.se/developer: developer@example.se   # real human identity / contact
    scouterna.se/github: GITHUB_USERNAME
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: GITHUB_USERNAME-admin
  namespace: PROJECT
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: admin
subjects:
  - kind: ServiceAccount
    name: GITHUB_USERNAME
    namespace: PROJECT

# ─────────────────────────────────────────────────────────────────────────────
# MULTI-NAMESPACE (dev/prod/staging) — pattern, not to be used verbatim.
#
# The `PROJECT` bulk-replace produces `namespace: PROJECT`, which does NOT exist
# for a dev/prod project (its namespaces are PROJECT-dev / PROJECT-prod). So:
#
#   1. Pin the ServiceAccount to ONE real namespace (convention: -dev).
#   2. Add one RoleBinding PER namespace. Note the two different namespace
#      fields: the RoleBinding's own metadata.namespace is WHERE access is
#      granted; subjects[].namespace is WHERE THE SA LIVES (always the SA's
#      home namespace, -dev here) — it stays the same in every RoleBinding.
#
# apiVersion: v1
# kind: ServiceAccount
# metadata:
#   name: GITHUB_USERNAME
#   namespace: PROJECT-dev            # SA lives here (its home)
#   annotations:
#     scouterna.se/developer: developer@example.se
#     scouterna.se/github: GITHUB_USERNAME
# ---
# apiVersion: rbac.authorization.k8s.io/v1
# kind: RoleBinding
# metadata:
#   name: GITHUB_USERNAME-admin
#   namespace: PROJECT-dev            # grants access in -dev
# roleRef:
#   apiGroup: rbac.authorization.k8s.io
#   kind: ClusterRole
#   name: admin
# subjects:
#   - kind: ServiceAccount
#     name: GITHUB_USERNAME
#     namespace: PROJECT-dev          # SA's home (unchanged below too)
# ---
# apiVersion: rbac.authorization.k8s.io/v1
# kind: RoleBinding
# metadata:
#   name: GITHUB_USERNAME-admin
#   namespace: PROJECT-prod           # grants access in -prod
# roleRef:
#   apiGroup: rbac.authorization.k8s.io
#   kind: ClusterRole
#   name: admin
# subjects:
#   - kind: ServiceAccount
#     name: GITHUB_USERNAME
#     namespace: PROJECT-dev          # STILL the SA's home namespace
# ─────────────────────────────────────────────────────────────────────────────
