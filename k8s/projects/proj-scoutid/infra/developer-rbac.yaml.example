# Per-developer namespace access. Copy this to developer-rbac.yaml (drop the
# .example) to activate it — the .example is never synced.
#
# Developers authenticate via GitHub SSO (Dex + AKS structured auth): a developer
# IS their GitHub identity. There is NO ServiceAccount and NO token to hand out.
# Access = a RoleBinding binding their OIDC user into each namespace.
#
# The OIDC username is `aks:jwt:<github-login>` (JWTAuthenticator prefixes the
# GitHub login). Use ClusterRole `admin` for full control within the namespace,
# or `view` for read-only. Add one RoleBinding per (developer, namespace); the
# developer needs one binding in EACH namespace they should access.
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: GITHUB_LOGIN-admin
  namespace: proj-scoutid          # e.g. proj-scoutid-dev / proj-scoutid-prod for a dual-env project
subjects:
  - kind: User
    name: "aks:jwt:GITHUB_LOGIN"
    apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: admin
  apiGroup: rbac.authorization.k8s.io
